# =============================================================
# Unclaimed Funds Intelligence Pipeline — environment variables
# Copy this file to `.env` and fill in real values.
# Never commit `.env` to source control.
# =============================================================

# --- PostgreSQL (used by docker-compose AND the app) ---
POSTGRES_USER=ufip
POSTGRES_PASSWORD=ufip_dev_password
POSTGRES_DB=ufip
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Full SQLAlchemy URL the app will use to connect.
# When running the app on the host (not inside Docker) use localhost.
DATABASE_URL=postgresql+psycopg2://ufip:ufip_dev_password@localhost:5432/ufip

# --- Airtable ---
# Generate a token at https://airtable.com/create/tokens
AIRTABLE_API_TOKEN=
AIRTABLE_BASE_ID=
AIRTABLE_TABLE_NAME=Leads

# --- Logging ---
LOG_LEVEL=INFO

# --- API server ---
API_HOST=0.0.0.0
API_PORT=8000

# CORS origins allowed to hit the API (comma-separated).
# Vite dev server defaults to 5173.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
